    "# ============================================================\n",
    "# MIMICEL Train / Validation / Test Split\n",
    "# Case-level split\n",
    "# Save outputs under ./results\n",
    "# ============================================================\n",
    "\n",
    "from pathlib import Path\n",
    "import pandas as pd\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 0. Config\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "DATA_PATH = \"./../MIMICEL_data/mimicel.csv\"\n",
    "\n",
    "OUT_DIR = Path(\"./../MIMICEL_data/\")\n",
    "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "CASE_COL = \"stay_id\"\n",
    "TIME_COL = \"timestamps\"\n",
    "\n",
    "TRAIN_RATIO = 0.70\n",
    "VAL_RATIO = 0.10\n",
    "TEST_RATIO = 0.20\n",
    "\n",
    "RANDOM_STATE = 42\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1. Load Dataset\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "print(\"[1] Loading dataset...\")\n",
    "\n",
    "df = pd.read_csv(\n",
    "    DATA_PATH,\n",
    "    low_memory=False\n",
    ")\n",
    "\n",
    "print(\"Original shape:\", df.shape)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2. Basic Preprocessing\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "print(\"[2] Preprocessing...\")\n",
    "\n",
    "df[TIME_COL] = pd.to_datetime(\n",
    "    df[TIME_COL],\n",
    "    errors=\"coerce\"\n",
    ")\n",
    "\n",
    "df = df.dropna(\n",
    "    subset=[CASE_COL, TIME_COL]\n",
    ")\n",
    "\n",
    "df = df.sort_values(\n",
    "    [CASE_COL, TIME_COL]\n",
    ").reset_index(drop=True)\n",
    "\n",
    "print(\"After preprocessing:\", df.shape)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3. Case-Level Split\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "print(\"[3] Splitting cases...\")\n",
    "\n",
    "case_ids = df[CASE_COL].unique()\n",
    "\n",
    "# First split: train vs temp(val+test)\n",
    "train_cases, temp_cases = train_test_split(\n",
    "    case_ids,\n",
    "    test_size=(VAL_RATIO + TEST_RATIO),\n",
    "    random_state=RANDOM_STATE,\n",
    "    shuffle=True\n",
    ")\n",
    "\n",
    "# Second split: val vs test\n",
    "val_relative_ratio = VAL_RATIO / (VAL_RATIO + TEST_RATIO)\n",
    "\n",
    "val_cases, test_cases = train_test_split(\n",
    "    temp_cases,\n",
    "    test_size=(1 - val_relative_ratio),\n",
    "    random_state=RANDOM_STATE,\n",
    "    shuffle=True\n",
    ")\n",
    "\n",
    "print(f\"Train cases: {len(train_cases):,}\")\n",
    "print(f\"Val cases  : {len(val_cases):,}\")\n",
    "print(f\"Test cases : {len(test_cases):,}\")\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4. Create Datasets\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "print(\"[4] Creating datasets...\")\n",
    "\n",
    "train_df = df[\n",
    "    df[CASE_COL].isin(train_cases)\n",
    "].copy()\n",
    "\n",
    "val_df = df[\n",
    "    df[CASE_COL].isin(val_cases)\n",
    "].copy()\n",
    "\n",
    "test_df = df[\n",
    "    df[CASE_COL].isin(test_cases)\n",
    "].copy()\n",
    "\n",
    "# sort again\n",
    "train_df = train_df.sort_values(\n",
    "    [CASE_COL, TIME_COL]\n",
    ").reset_index(drop=True)\n",
    "\n",
    "val_df = val_df.sort_values(\n",
    "    [CASE_COL, TIME_COL]\n",
    ").reset_index(drop=True)\n",
    "\n",
    "test_df = test_df.sort_values(\n",
    "    [CASE_COL, TIME_COL]\n",
    ").reset_index(drop=True)\n",
    "\n",
    "print(\"Train shape:\", train_df.shape)\n",
    "print(\"Val shape  :\", val_df.shape)\n",
    "print(\"Test shape :\", test_df.shape)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 5. Save CSV\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "print(\"[5] Saving datasets...\")\n",
    "\n",
    "train_path = OUT_DIR / \"mimicel_train.csv\"\n",
    "val_path = OUT_DIR / \"mimicel_val.csv\"\n",
    "test_path = OUT_DIR / \"mimicel_test.csv\"\n",
    "\n",
    "train_df.to_csv(\n",
    "    train_path,\n",
    "    index=False\n",
    ")\n",
    "\n",
    "val_df.to_csv(\n",
    "    val_path,\n",
    "    index=False\n",
    ")\n",
    "\n",
    "test_df.to_csv(\n",
    "    test_path,\n",
    "    index=False\n",
    ")\n",
    "\n",
    "print(\"Saved:\")\n",
    "print(train_path)\n",
    "print(val_path)\n",
    "print(test_path)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 6. Save Metadata\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "metadata = {\n",
    "    \"original_rows\": len(df),\n",
    "\n",
    "    \"train_rows\": len(train_df),\n",
    "    \"val_rows\": len(val_df),\n",
    "    \"test_rows\": len(test_df),\n",
    "\n",
    "    \"original_cases\": df[CASE_COL].nunique(),\n",
    "\n",
    "    \"train_cases\": train_df[CASE_COL].nunique(),\n",
    "    \"val_cases\": val_df[CASE_COL].nunique(),\n",
    "    \"test_cases\": test_df[CASE_COL].nunique(),\n",
    "\n",
    "    \"train_ratio\": TRAIN_RATIO,\n",
    "    \"val_ratio\": VAL_RATIO,\n",
    "    \"test_ratio\": TEST_RATIO,\n",
    "\n",
    "    \"random_state\": RANDOM_STATE\n",
    "}\n",
    "\n",
    "metadata_df = pd.DataFrame(\n",
    "    metadata.items(),\n",
    "    columns=[\"metric\", \"value\"]\n",
    ")\n",
    "\n",
    "metadata_df.to_csv(\n",
    "    OUT_DIR / \"mimicel_split_metadata.csv\",\n",
    "    index=False\n",
    ")\n",
    "\n",
    "print(\"\\nSplit Metadata\")\n",
    "print(metadata_df)\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 7. Leakage Check\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "print(\"\\n[6] Leakage check...\")\n",
    "\n",
    "train_case_set = set(train_df[CASE_COL].unique())\n",
    "val_case_set = set(val_df[CASE_COL].unique())\n",
    "test_case_set = set(test_df[CASE_COL].unique())\n",
    "\n",
    "train_val_overlap = train_case_set.intersection(val_case_set)\n",
    "train_test_overlap = train_case_set.intersection(test_case_set)\n",
    "val_test_overlap = val_case_set.intersection(test_case_set)\n",
    "\n",
    "print(f\"Train-Val overlap : {len(train_val_overlap)}\")\n",
    "print(f\"Train-Test overlap: {len(train_test_overlap)}\")\n",
    "print(f\"Val-Test overlap  : {len(val_test_overlap)}\")\n",
    "\n",
    "if (\n",
    "    len(train_val_overlap) == 0\n",
    "    and len(train_test_overlap) == 0\n",
    "    and len(val_test_overlap) == 0\n",
    "):\n",
    "    print(\"No leakage detected.\")\n",
    "else:\n",
    "    print(\"WARNING: Leakage detected.\")\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 8. Summary Report\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "summary_txt = OUT_DIR / \"mimicel_split_summary.txt\"\n",
    "\n",
    "with open(summary_txt, \"w\", encoding=\"utf-8\") as f:\n",
    "\n",
    "    f.write(\"MIMICEL Train/Val/Test Split Summary\\n\")\n",
    "    f.write(\"=\" * 60 + \"\\n\\n\")\n",
    "\n",
    "    f.write(f\"Original rows : {len(df):,}\\n\")\n",
    "\n",
    "    f.write(f\"Train rows    : {len(train_df):,}\\n\")\n",
    "    f.write(f\"Val rows      : {len(val_df):,}\\n\")\n",
    "    f.write(f\"Test rows     : {len(test_df):,}\\n\\n\")\n",
    "\n",
    "    f.write(f\"Original cases: {df[CASE_COL].nunique():,}\\n\")\n",
    "\n",
    "    f.write(f\"Train cases   : {train_df[CASE_COL].nunique():,}\\n\")\n",
    "    f.write(f\"Val cases     : {val_df[CASE_COL].nunique():,}\\n\")\n",
    "    f.write(f\"Test cases    : {test_df[CASE_COL].nunique():,}\\n\\n\")\n",
    "\n",
    "    f.write(f\"Train ratio   : {TRAIN_RATIO}\\n\")\n",
    "    f.write(f\"Val ratio     : {VAL_RATIO}\\n\")\n",
    "    f.write(f\"Test ratio    : {TEST_RATIO}\\n\\n\")\n",
    "\n",
    "    f.write(f\"Random state  : {RANDOM_STATE}\\n\\n\")\n",
    "\n",
    "    f.write(f\"Train-Val overlap : {len(train_val_overlap)}\\n\")\n",
    "    f.write(f\"Train-Test overlap: {len(train_test_overlap)}\\n\")\n",
    "    f.write(f\"Val-Test overlap  : {len(val_test_overlap)}\\n\")\n",
    "\n",
    "print(\"\\nDone.\")\n",
    "print(f\"Outputs saved to: {OUT_DIR.resolve()}\")"
